{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(node scripts/*)",
      "Read(cell-catalog/**)",
      "Read(cell-orders/**)",
      "Read(frontend/**)",
      "Read(cell-catalog/contracts/**)",
      "Read(cell-orders/contracts/**)",
      "Write(cell-catalog/**)",
      "Write(cell-orders/**)",
      "Write(frontend/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "CELL=$(echo $CLAUDE_TOOL_INPUT_FILE_PATH | grep -o 'cell-[^/]*' | head -1); echo \"✅ [AgriParts] ${CLAUDE_TOOL_INPUT_FILE_PATH} | Cell: ${CELL:-root/shared}\""
          }
        ]
      }
    ]
  }
}
